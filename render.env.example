# Wklej te zmienne w Render Dashboard → konfigurator-stal-pol-api → Environment
# (FIREBASE_PROJECT_ID i PORT są już w render.yaml)

# Wygeneruj jedną linię JSON:
#   cd backend && ./scripts/print-render-env.sh
FIREBASE_SERVICE_ACCOUNT_JSON=

# Po deployu frontendu na Vercel — podmień na właściwy URL (bez końcowego /)
CORS_ORIGINS=https://konfigurator-stal-pol.vercel.app,http://localhost:3000,http://localhost:3001
