# Zmienne — Vercel Dashboard (opcjonalnie, jeśli nie używasz .env.production z repo)
# W produkcji NEXT_PUBLIC_API_URL zostaw PUSTE — Next.js proxy /api → Render (next.config.ts)

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=konfigurator-stal-pol.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=konfigurator-stal-pol
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=konfigurator-stal-pol.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=336308273868
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcjonalnie — tylko jeśli chcesz bez proxy (bezpośrednio do Render):
# NEXT_PUBLIC_API_URL=https://konfigurator-stal-pol.onrender.com
